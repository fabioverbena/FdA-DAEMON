# Copia questo file in local.env e compila i valori per il tuo PC.
# local.env NON viene committato (è in .gitignore).

# ── Percorsi Mexal (autodetect se non specificato) ──────────────────────────
# MEXAL_TEMP=C:\Passepartout\PassClient\mxdesk1205143000\temp

# ── Cartelle di archiviazione locale ────────────────────────────────────────
# BOLLE_DIR=C:\Users\<utente>\Desktop\2026\BOLLE 2026
# FATTURE_DIR=C:\Users\<utente>\Desktop\2026\FATTURE 2026
# ORDINI_DIR=C:\Users\<utente>\Desktop\2026\ORDINI 2026
# PREVENTIVI_DIR=C:\Users\<utente>\Desktop\2026\PREVENTIVI 2026
# ORDINI_FORNITORI_DIR=C:\Users\<utente>\Desktop\2026\ORDINI A FORNITORI 2026

# ── Supabase CRM ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role_key>

# ── Google Drive (Procedura Documentale) ────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GDRIVE_INBOX_PD_FOLDER_ID=

# ── Telegram notifiche ───────────────────────────────────────────────────────
